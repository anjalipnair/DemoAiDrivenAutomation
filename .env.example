# CI/CD Environment Configuration
# Copy this to .env and customize for your environment

# Test Configuration
CI=true
BASE_URL=https://www.orangehrm.com
TEST_TIMEOUT=30000
HEADLESS=true

# Browser Configuration
BROWSER_CHROMIUM=true
BROWSER_FIREFOX=true
BROWSER_WEBKIT=true

# Reporting Configuration
REPORT_FORMAT=html,json
REPORT_DIR=./playwright-report
RESULTS_DIR=./test-results

# Notification Configuration
SLACK_WEBHOOK=
TEAMS_WEBHOOK=
EMAIL_RECIPIENTS=

# Schedule Configuration
DAILY_SCHEDULE=0 6 * * *
WEEKLY_SCHEDULE=0 6 * * 1

# Database Configuration (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_results
DB_USER=testuser
DB_PASS=testpass

# CI Platform Specific
# GitHub Actions
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# Jenkins
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=

# GitLab
GITLAB_TOKEN=

# Performance Thresholds
MAX_TEST_DURATION=600
FAILURE_THRESHOLD=10
SUCCESS_RATE_THRESHOLD=95

# Retry Configuration
MAX_RETRIES=2
RETRY_DELAY=5000

# Parallel Execution
MAX_WORKERS=3
WORKER_TIMEOUT=300