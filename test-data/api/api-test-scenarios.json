{
  "testScenarios": {
    "authentication": {
      "validLogin": {
        "description": "Successful authentication with valid credentials",
        "requests": [
          {
            "username": "standard_user",
            "password": "secret_sauce"
          },
          {
            "username": "performance_glitch_user", 
            "password": "secret_sauce"
          }
        ],
        "expectedResponse": {
          "statusCode": 200,
          "requiredFields": ["sessionToken", "user", "expiresIn"],
          "userFields": ["id", "username", "userType"]
        }
      },
      "invalidCredentials": {
        "description": "Authentication failures with various invalid inputs",
        "requests": [
          {
            "username": "invalid_user",
            "password": "secret_sauce",
            "expectedError": "AUTH001",
            "expectedMessage": "Invalid username or password"
          },
          {
            "username": "standard_user",
            "password": "wrong_password",
            "expectedError": "AUTH001", 
            "expectedMessage": "Invalid username or password"
          }
        ],
        "expectedResponse": {
          "statusCode": 401,
          "requiredFields": ["error", "message"]
        }
      },
      "lockedUser": {
        "description": "Authentication attempt with locked account",
        "requests": [
          {
            "username": "locked_out_user",
            "password": "secret_sauce",
            "expectedError": "AUTH002",
            "expectedMessage": "User account is locked"
          }
        ],
        "expectedResponse": {
          "statusCode": 401
        }
      },
      "missingFields": {
        "description": "Validation for required authentication fields",
        "requests": [
          {
            "username": "",
            "password": "secret_sauce",
            "expectedError": "VALIDATION_ERROR",
            "expectedMessage": "Username is required"
          },
          {
            "username": "standard_user", 
            "password": "",
            "expectedError": "VALIDATION_ERROR",
            "expectedMessage": "Password is required"
          },
          {
            "expectedError": "VALIDATION_ERROR",
            "expectedMessage": "Username and password are required"
          }
        ],
        "expectedResponse": {
          "statusCode": 400
        }
      }
    },
    "inventory": {
      "getAllProducts": {
        "description": "Retrieve complete product catalog",
        "requests": [
          {
            "queryParams": {}
          },
          {
            "queryParams": {
              "limit": 10,
              "offset": 0
            }
          }
        ],
        "expectedResponse": {
          "statusCode": 200,
          "requiredFields": ["products", "totalCount"],
          "productFields": ["id", "name", "description", "price", "image", "inventoryCount"],
          "validation": {
            "productsCount": 6,
            "totalCount": 6
          }
        }
      },
      "productSorting": {
        "description": "Test product sorting functionality",
        "requests": [
          {
            "queryParams": {
              "sortBy": "name",
              "sortOrder": "asc"
            },
            "expectedOrder": ["sauce-labs-backpack", "sauce-labs-bike-light", "sauce-labs-bolt-t-shirt", "sauce-labs-fleece-jacket", "sauce-labs-onesie", "test-allthethings-t-shirt-red"]
          },
          {
            "queryParams": {
              "sortBy": "price", 
              "sortOrder": "asc"
            },
            "expectedOrder": ["sauce-labs-onesie", "sauce-labs-bike-light", "sauce-labs-bolt-t-shirt", "test-allthethings-t-shirt-red", "sauce-labs-backpack", "sauce-labs-fleece-jacket"]
          }
        ]
      },
      "getProductDetails": {
        "description": "Retrieve individual product information",
        "requests": [
          {
            "productId": "sauce-labs-backpack",
            "expectedName": "Sauce Labs Backpack",
            "expectedPrice": 29.99
          },
          {
            "productId": "sauce-labs-bike-light",
            "expectedName": "Sauce Labs Bike Light", 
            "expectedPrice": 9.99
          }
        ]
      },
      "invalidProductId": {
        "description": "Handle requests for non-existent products",
        "requests": [
          {
            "productId": "non-existent-product",
            "expectedError": "PRODUCT_NOT_FOUND",
            "expectedStatusCode": 404
          }
        ]
      }
    },
    "cart": {
      "emptyCart": {
        "description": "Retrieve empty cart for authenticated user",
        "expectedResponse": {
          "statusCode": 200,
          "requiredFields": ["cartId", "items", "itemCount", "totalAmount"],
          "validation": {
            "itemCount": 0,
            "totalAmount": 0,
            "itemsLength": 0
          }
        }
      },
      "addSingleItem": {
        "description": "Add single product to cart",
        "requests": [
          {
            "productId": "sauce-labs-backpack",
            "quantity": 1
          }
        ],
        "expectedResponse": {
          "statusCode": 201,
          "validation": {
            "itemCount": 1,
            "totalAmount": 29.99
          }
        }
      },
      "addMultipleItems": {
        "description": "Add multiple different products to cart",
        "requests": [
          {
            "productId": "sauce-labs-backpack", 
            "quantity": 1
          },
          {
            "productId": "sauce-labs-bike-light",
            "quantity": 2
          }
        ],
        "expectedResponse": {
          "validation": {
            "itemCount": 3,
            "totalAmount": 49.97
          }
        }
      },
      "updateItemQuantity": {
        "description": "Update quantity of existing cart item",
        "setup": [
          {
            "productId": "sauce-labs-backpack",
            "quantity": 1
          }
        ],
        "requests": [
          {
            "productId": "sauce-labs-backpack",
            "quantity": 3
          }
        ],
        "expectedResponse": {
          "validation": {
            "itemCount": 3,
            "totalAmount": 89.97
          }
        }
      },
      "removeItem": {
        "description": "Remove item from cart",
        "setup": [
          {
            "productId": "sauce-labs-backpack",
            "quantity": 1
          },
          {
            "productId": "sauce-labs-bike-light", 
            "quantity": 1
          }
        ],
        "requests": [
          {
            "productId": "sauce-labs-backpack",
            "method": "DELETE"
          }
        ],
        "expectedResponse": {
          "validation": {
            "itemCount": 1,
            "totalAmount": 9.99
          }
        }
      },
      "invalidProductAdd": {
        "description": "Handle adding non-existent product to cart", 
        "requests": [
          {
            "productId": "invalid-product-id",
            "quantity": 1,
            "expectedError": "CART001",
            "expectedMessage": "Product not found",
            "expectedStatusCode": 404
          }
        ]
      }
    },
    "checkout": {
      "validCustomerInfo": {
        "description": "Submit valid customer information",
        "setup": "cart_with_items",
        "requests": [
          {
            "firstName": "John",
            "lastName": "Doe",
            "postalCode": "12345"
          },
          {
            "firstName": "Jane",
            "lastName": "Smith", 
            "postalCode": "67890"
          }
        ],
        "expectedResponse": {
          "statusCode": 200
        }
      },
      "invalidCustomerInfo": {
        "description": "Validation for required customer fields",
        "requests": [
          {
            "firstName": "",
            "lastName": "Doe",
            "postalCode": "12345", 
            "expectedError": "CHECKOUT001",
            "expectedMessage": "First Name is required"
          },
          {
            "firstName": "John",
            "lastName": "",
            "postalCode": "12345",
            "expectedError": "CHECKOUT001", 
            "expectedMessage": "Last Name is required"
          },
          {
            "firstName": "John",
            "lastName": "Doe",
            "postalCode": "",
            "expectedError": "CHECKOUT001",
            "expectedMessage": "Postal Code is required"
          }
        ],
        "expectedResponse": {
          "statusCode": 400
        }
      },
      "orderSummary": {
        "description": "Generate accurate order summary with tax calculations",
        "setup": "cart_with_items_and_customer_info",
        "expectedResponse": {
          "statusCode": 200,
          "requiredFields": ["items", "subtotal", "tax", "shipping", "total", "paymentInfo", "shippingInfo"],
          "validation": {
            "taxRate": 0.08,
            "shippingCost": 0
          }
        }
      },
      "completeOrder": {
        "description": "Successfully complete order processing",
        "setup": "complete_checkout_flow",
        "expectedResponse": {
          "statusCode": 200,
          "requiredFields": ["orderId", "status", "confirmationMessage", "trackingInfo"],
          "validation": {
            "status": "completed"
          }
        }
      },
      "emptyCartCheckout": {
        "description": "Prevent checkout with empty cart",
        "setup": "empty_cart",
        "requests": [
          {
            "firstName": "John",
            "lastName": "Doe", 
            "postalCode": "12345",
            "expectedError": "CART003",
            "expectedMessage": "Cart is empty",
            "expectedStatusCode": 400
          }
        ]
      }
    }
  },
  "testDataSets": {
    "users_api": {
      "validUsers": ["standard_user", "performance_glitch_user", "problem_user"],
      "invalidUsers": ["locked_out_user", "invalid_user"],
      "testCombinations": "all_users_x_all_scenarios"
    },
    "products_api": {
      "singleProduct": ["sauce-labs-backpack"],
      "multipleProducts": ["sauce-labs-backpack", "sauce-labs-bike-light"],
      "allProducts": ["sauce-labs-backpack", "sauce-labs-bike-light", "test-allthethings-t-shirt-red", "sauce-labs-fleece-jacket", "sauce-labs-onesie", "sauce-labs-bolt-t-shirt"]
    },
    "cart_scenarios": {
      "empty_cart": [],
      "single_item": [{"productId": "sauce-labs-backpack", "quantity": 1}],
      "multiple_items": [
        {"productId": "sauce-labs-backpack", "quantity": 1},
        {"productId": "sauce-labs-bike-light", "quantity": 2}
      ],
      "high_quantity": [{"productId": "sauce-labs-onesie", "quantity": 10}]
    }
  },
  "performance_benchmarks": {
    "authentication": {
      "login": {"maxResponseTime": 2000, "expectedTime": 500},
      "logout": {"maxResponseTime": 1000, "expectedTime": 300}
    },
    "inventory": {
      "getProducts": {"maxResponseTime": 3000, "expectedTime": 1000},
      "getProduct": {"maxResponseTime": 1500, "expectedTime": 400}
    },
    "cart": {
      "addItem": {"maxResponseTime": 2000, "expectedTime": 600},
      "getCart": {"maxResponseTime": 2000, "expectedTime": 500}
    },
    "checkout": {
      "completeOrder": {"maxResponseTime": 5000, "expectedTime": 2000}
    }
  }
}