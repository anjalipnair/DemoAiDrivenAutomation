{
  "performanceEnvironments": {
    "loadTesting": {
      "name": "Load Testing Environment",
      "baseUrl": "https://load-test.saucedemo.com",
      "timeout": 30000,
      "retries": 0,
      "monitoring": {
        "enabled": true,
        "metricsCollection": "detailed",
        "samplingRate": 1.0
      },
      "infrastructure": {
        "serverCount": 3,
        "loadBalancer": true,
        "autoScaling": true
      }
    },
    "stressTesting": {
      "name": "Stress Testing Environment",
      "baseUrl": "https://stress-test.saucedemo.com",
      "timeout": 60000,
      "retries": 0,
      "monitoring": {
        "enabled": true,
        "metricsCollection": "comprehensive",
        "samplingRate": 1.0
      },
      "infrastructure": {
        "serverCount": 5,
        "loadBalancer": true,
        "autoScaling": true,
        "redundancy": "high"
      }
    },
    "enduranceTesting": {
      "name": "Endurance Testing Environment", 
      "baseUrl": "https://endurance-test.saucedemo.com",
      "timeout": 45000,
      "retries": 1,
      "monitoring": {
        "enabled": true,
        "metricsCollection": "timeline",
        "samplingRate": 0.1,
        "longTermStorage": true
      },
      "infrastructure": {
        "serverCount": 2,
        "loadBalancer": false,
        "autoScaling": false
      }
    }
  },
  "monitoringConfiguration": {
    "metrics": {
      "responseTime": {
        "enabled": true,
        "percentiles": [50, 75, 90, 95, 99],
        "alertThresholds": [500, 1000, 2000]
      },
      "throughput": {
        "enabled": true,
        "measurements": ["rps", "concurrent_users"],
        "alertThresholds": [50, 25]
      },
      "errorRate": {
        "enabled": true,
        "measurements": ["4xx", "5xx", "timeout"],
        "alertThresholds": [1, 5, 10]
      },
      "resourceUtilization": {
        "enabled": true,
        "measurements": ["cpu", "memory", "disk", "network"],
        "alertThresholds": [70, 85, 95]
      }
    },
    "reporting": {
      "realTime": true,
      "historical": true,
      "alerts": true,
      "dashboards": ["grafana", "custom"]
    }
  }
}
